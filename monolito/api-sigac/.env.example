DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sigac?schema=public"
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio-en-produccion"
# Documento arquitectónico: JWT de vida corta (~1 h)
JWT_EXPIRES_IN="1h"
