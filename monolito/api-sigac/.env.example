# Origen del front (Next.js por defecto en monolito/sigac: puerto 3001)
FRONTEND_ORIGIN=http://localhost:3001

# Tras `npx prisma db seed`: usuario ADMIN de prueba (ver comentarios en prisma/seed.ts)
